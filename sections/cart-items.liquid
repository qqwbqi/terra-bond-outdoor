<section class="section" data-section-id="{{ section.id }}" style="display:grid;grid-template-columns:2fr 1fr;gap:32px;">
  <div>
    <div class="cart-item">
      <div class="cart-item-img">🎨</div>
      <div class="cart-item-info"><h4>20-Color Bonded Stone Surface Sample Kit</h4><p>20 cured color samples · 7–12 day shipping</p></div>
      <div style="font-weight:700;color:var(--color-text);">$14.99</div>
    </div>
    <div class="success-box" style="margin-top:24px;"><strong>You're $35.01 away from free shipping!</strong> Add a DIY Test Kit to your order.</div>
    <div style="margin-top:32px;padding:24px;background:var(--color-card-bg);border-radius:var(--radius);box-shadow:var(--color-shadow);border:1px solid var(--color-border);">
      <h3 style="color:var(--color-text);margin-bottom:12px;font-size:16px;">Recommended Add-Ons</h3>
      <div style="display:flex;gap:16px;align-items:center;">
        <div style="width:60px;height:60px;background:var(--color-bg-sand);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:28px;">🧪</div>
        <div style="flex:1;"><div style="font-weight:600;color:var(--color-text);">DIY 1 sq ft Test Kit</div><div style="font-size:13px;color:var(--color-text-light);">Test application before full project</div></div>
        <div style="font-weight:700;color:var(--color-accent);">$39.99</div>
        <a href="#" class="btn btn-primary" style="padding:8px 16px;font-size:13px;">Add</a>
      </div>
    </div>
  </div>
  <div class="cart-summary">
    <h3 style="color:var(--color-text);margin-bottom:16px;">Order Summary</h3>
    <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:14px;"><span>Subtotal</span><span>$14.99</span></div>
    <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:14px;"><span>Shipping</span><span>Calculated at checkout</span></div>
    <div style="border-top:1px solid var(--color-border);margin:16px 0;padding-top:16px;display:flex;justify-content:space-between;font-weight:700;color:var(--color-text);"><span>Total</span><span>$14.99 USD</span></div>
    <a href="/checkout.html" class="btn btn-primary" style="width:100%;text-align:center;">Proceed to Checkout</a>
    <div class="disclaimer-box" style="margin-top:16px;font-size:12px;">Sample kit ships to the U.S. in 7–12 days. Bulk orders quoted separately.</div>
  </div>
</section>

{% schema %}
{
  "name": "Cart Items",
  "presets": [{"name": "Cart Items"}]
}
{% endschema %}

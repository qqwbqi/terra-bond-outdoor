<section class="hero-section" data-section-id="{{ section.id }}" style="background-image:url('{{ section.settings.hero_image | default: 'https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=1920&q=80' }}')">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-card">
      <h1>{{ section.settings.heading | default: 'Transform Plain Concrete Into a Natural Stone Look' }}</h1>
      <p>{{ section.settings.subheading | default: 'Order a 20-color sample kit, compare real bonded stone surfaces at home, and request a bulk quote when your patio, pool deck, or garden path project is ready.' }}</p>
      <div class="hero-buttons">
        <a href="{{ section.settings.button_link_1 | default: '/sample-kit.html' }}" class="btn btn-primary btn-lg">
          {{ section.settings.button_text_1 | default: 'Order Sample Kit' }}
        </a>
        <a href="{{ section.settings.button_link_2 | default: '/project-estimate.html' }}" class="btn btn-secondary btn-lg">
          {{ section.settings.button_text_2 | default: 'Request Bulk Quote' }}
        </a>
      </div>
      <div class="hero-trust">
        <i data-lucide="check-circle-2" style="width:16px;height:16px"></i>
        <span>{{ section.settings.trust_text | default: '20 cured stone samples · $14.99 · Ships to U.S. in 7–12 days' }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {"type": "image_picker", "id": "hero_image", "label": "Hero Background Image"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Transform Plain Concrete Into a Natural Stone Look"},
    {"type": "textarea", "id": "subheading", "label": "Subheading", "default": "Order a 20-color sample kit..."},
    {"type": "text", "id": "button_text_1", "label": "Button 1 Text", "default": "Order Sample Kit"},
    {"type": "url", "id": "button_link_1", "label": "Button 1 Link", "default": "/sample-kit.html"},
    {"type": "text", "id": "button_text_2", "label": "Button 2 Text", "default": "Request Bulk Quote"},
    {"type": "url", "id": "button_link_2", "label": "Button 2 Link", "default": "/project-estimate.html"},
    {"type": "text", "id": "trust_text", "label": "Trust Line", "default": "20 cured stone samples · $14.99 · Ships to U.S. in 7–12 days"}
  ],
  "presets": [{"name": "Hero"}]
}
{% endschema %}

<section class="section" style="max-width:600px" data-section-id="{{ section.id }}">
  <div class="cart-item" style="margin-bottom:32px">
    <div class="cart-item-drawer-img"><img src="https://images.unsplash.com/photo-1622372738982-bdf473216834?w=200&q=80" alt="Sample Kit"></div>
    <div class="cart-item-drawer-info"><h4>20-Color Bonded Stone Surface Sample Kit</h4><p class="qty">$14.99 · 7–12 day shipping</p></div>
  </div>
  <div class="form-card">
    <form data-success="This is a prototype checkout. In production, this would use Shopify native checkout.">
      <h3 style="color:var(--color-text);margin-bottom:16px;font-size:18px">Contact Information</h3>
      <div class="form-group"><label>Email *</label><input type="email" required></div>
      <h3 style="color:var(--color-text);margin:32px 0 16px;font-size:18px">Shipping Address</h3>
      <div class="form-group"><label>Full Name *</label><input type="text" required></div>
      <div class="form-group"><label>Address *</label><input type="text" required></div>
      <div class="form-group"><label>City *</label><input type="text" required></div>
      <div class="form-row">
        <div class="form-group"><label>State *</label><input type="text" required></div>
        <div class="form-group"><label>ZIP *</label><input type="text" required></div>
      </div>
      <h3 style="color:var(--color-text);margin:32px 0 16px;font-size:18px">Shipping Method</h3>
      <div style="background:var(--color-card-bg);padding:16px;border-radius:var(--radius);margin-bottom:24px;border:1px solid var(--color-border)">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div><div style="font-weight:600">Standard Shipping</div><div style="font-size:13px;color:var(--color-text-light)">7–12 business days</div></div>
          <div style="font-weight:700">$5.00</div>
        </div>
      </div>
      <div class="disclaimer-box" style="margin-bottom:24px"><strong>Reminder:</strong> Sample kit ships to the U.S. in 7–12 days. Bulk orders are quoted separately.</div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;font-size:20px;font-weight:700;color:var(--color-dark)"><span>Total</span><span>$19.99 USD</span></div>
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%">Complete Order</button>
      <p style="text-align:center;margin-top:16px;font-size:12px;color:var(--color-text-light)">Secure checkout powered by Shopify</p>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Checkout Form",
  "presets": [{"name": "Checkout Form"}]
}
{% endschema %}

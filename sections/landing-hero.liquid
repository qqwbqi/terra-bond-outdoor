<section class="landing-hero" data-section-id="{{ section.id }}" style="background-image:url('https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=1920&q=80')">
  <div class="hero-overlay"></div>
  <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
    <h1>{{ section.settings.heading | default: 'Transform Plain Concrete Into a Natural Stone Look' }}</h1>
    <p>{{ section.settings.subheading | default: 'Order a 20-color sample kit and compare real bonded stone surfaces in your own space before planning your project.' }}</p>
    <a href="{{ section.settings.button_link | default: '/sample-kit.html' }}" class="btn btn-white btn-lg">{{ section.settings.button_text | default: 'Order Sample Kit' }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Landing Hero",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading"},
    {"type": "textarea", "id": "subheading", "label": "Subheading"},
    {"type": "text", "id": "button_text", "label": "Button Text", "default": "Order Sample Kit"},
    {"type": "text", "id": "button_link", "label": "Button Link", "default": "/sample-kit.html"}
  ],
  "presets": [{"name": "Landing Hero"}]
}
{% endschema %}

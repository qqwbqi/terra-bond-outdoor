<section class="section" data-section-id="{{ section.id }}">
  <div class="card-grid" style="max-width:700px;margin:0 auto 48px">
    <div class="card text-center"><div class="card-icon" style="margin:0 auto 20px"><i data-lucide="mail" style="width:28px;height:28px"></i></div><h3>Email</h3><p>support@terrabondoutdoor.com</p></div>
    <div class="card text-center"><div class="card-icon" style="margin:0 auto 20px"><i data-lucide="clock" style="width:28px;height:28px"></i></div><h3>Hours</h3><p>Mon–Fri, 9am–6pm EST</p></div>
  </div>
  <div class="form-card" style="max-width:700px;margin:0 auto">
    <h2 class="section-title" style="margin-bottom:32px">Send a Message</h2>
    <form data-success="Message sent! We will respond within 24 hours.">
      <div class="form-row">
        <div class="form-group"><label>Name *</label><input type="text" required></div>
        <div class="form-group"><label>Email *</label><input type="email" required></div>
      </div>
      <div class="form-group"><label>Subject</label><select><option>Sample Kit Question</option><option>Project Estimate</option><option>Dealer Program</option><option>Installation Help</option><option>Shipping / Returns</option><option>Other</option></select></div>
      <div class="form-group"><label>Message *</label><textarea rows="5" required></textarea></div>
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%">Send Message</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "presets": [{"name": "Contact Form"}]
}
{% endschema %>

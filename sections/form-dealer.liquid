<section class="section section-bg-sand" data-section-id="{{ section.id }}">
  <div class="two-col" style="max-width:1100px;margin:0 auto">
    <div>
      <h2 class="section-title section-title-left" style="margin-bottom:24px">Why Partner With TerraBond?</h2>
      <p class="mb-6" style="color:var(--color-text-light);font-size:17px;line-height:1.7">We provide landscape contractors, material suppliers, and outdoor designers with high-quality, durable resin-bound stone systems. Expand your service offerings with a premium product that homeowners love.</p>
      <div class="dealer-benefit">
        <div class="dealer-benefit-icon"><i data-lucide="wrench" style="width:24px;height:24px"></i></div>
        <div><h4>Professional Sample Box</h4><p>Get our comprehensive contractor presentation kit to show clients real cured samples on-site.</p></div>
      </div>
      <div class="dealer-benefit">
        <div class="dealer-benefit-icon"><i data-lucide="file-text" style="width:24px;height:24px"></i></div>
        <div><h4>Wholesale Bulk Pricing</h4><p>Access tiered volume discounts to maximize your margin on large residential or commercial installs.</p></div>
      </div>
      <div class="dealer-benefit">
        <div class="dealer-benefit-icon"><i data-lucide="truck" style="width:24px;height:24px"></i></div>
        <div><h4>Direct Site Delivery</h4><p>We arrange LTL freight shipping directly to your project site or warehouse anywhere in the US.</p></div>
      </div>
    </div>

    <div class="dealer-form-card">
      <h3 style="font-size:24px;font-weight:700;color:var(--color-dark);margin-bottom:24px">Dealer Application</h3>
      <form data-success="Dealer application submitted! We will review and contact you within 2 business days.">
        <div class="form-group"><input type="text" required placeholder="Company Name *"></div>
        <div class="form-row">
          <div class="form-group"><input type="text" required placeholder="Contact Name *"></div>
          <div class="form-group"><input type="tel" required placeholder="Phone *"></div>
        </div>
        <div class="form-group"><input type="email" required placeholder="Business Email *"></div>
        <div class="form-group"><input type="text" placeholder="Website"></div>
        <div class="form-group">
          <select><option value="" disabled selected>Business Type *</option><option>Landscape Contractor</option><option>Hardscape Installer</option><option>Material Supplier / Distributor</option><option>Pool Builder</option><option>Other</option></select>
        </div>
        <div class="form-group">
          <select><option value="" disabled selected>Need Dealer Sample Box? *</option><option>Yes, I want to purchase the Pro Sample Box</option><option>Not right now, just need pricing</option></select>
        </div>
        <button type="submit" class="btn btn-dark btn-lg" style="width:100%;margin-top:16px">Submit Application</button>
      </form>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dealer Form",
  "presets": [{"name": "Dealer Form"}]
}
{% endschema %}

<section class="section" data-section-id="{{ section.id }}">
  <h2 class="section-title">Returns</h2>
  <div class="card-grid" style="max-width:900px;margin:0 auto">
    <div class="card"><h3>Sample Kits</h3><p>Unused kits can be returned within 14 days. Customer is responsible for return shipping unless damaged.</p></div>
    <div class="card"><h3>DIY Test Kits</h3><p>Unused kits can be returned within 14 days. Once opened, test kits are not eligible for return.</p></div>
    <div class="card"><h3>Bulk Materials</h3><p>Bulk orders are custom quoted. Once materials are prepared or shipped, they are not eligible for standard returns.</p></div>
  </div>
</section>

{% schema %}
{
  "name": "Returns Policy",
  "presets": [{"name": "Returns Policy"}]
}
{% endschema %}
